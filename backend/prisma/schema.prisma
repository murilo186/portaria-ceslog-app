generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PerfilUsuario {
  ADMIN
  OPERADOR
}

enum TurnoUsuario {
  MANHA
  TARDE
}

enum StatusRelatorio {
  ABERTO
  FECHADO
}

enum PerfilPessoa {
  VISITANTE
  FORNECEDOR
  PRESTADOR
  PARCEIRO
  COLABORADOR
  AGREGADO
}

model Usuario {
  id              Int              @id @default(autoincrement())
  nome            String
  usuario         String           @unique
  email           String?          @unique
  senhaHash       String
  perfil          PerfilUsuario
  turno           TurnoUsuario?
  ativo           Boolean          @default(true)
  criadoEm        DateTime         @default(now())

  relatorioItens  RelatorioItem[]

  @@map("usuarios")
}

model Relatorio {
  id              Int              @id @default(autoincrement())
  dataRelatorio   DateTime         @unique
  status          StatusRelatorio  @default(ABERTO)
  criadoEm        DateTime         @default(now())
  finalizadoEm    DateTime?

  itens           RelatorioItem[]

  @@map("relatorios")
}

model RelatorioItem {
  id              Int        @id @default(autoincrement())
  relatorioId     Int
  usuarioId       Int
  perfilPessoa    PerfilPessoa @default(VISITANTE)
  empresa         String
  placaVeiculo    String
  nome            String
  horaEntrada     String?
  horaSaida       String?
  observacoes     String?
  turno           String?
  criadoEm        DateTime   @default(now())

  relatorio       Relatorio  @relation(fields: [relatorioId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  usuario         Usuario    @relation(fields: [usuarioId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([relatorioId])
  @@index([usuarioId])
  @@map("relatorio_itens")
}

